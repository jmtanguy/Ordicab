{
  "name": "ordicab-electron",
  "productName": "Ordicab",
  "version": "1.0.0-beta.3",
  "description": "Ordicab desktop foundation built with Electron, React, and TypeScript",
  "main": "./out/main/index.js",
  "author": "Ordicab",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Ordicab/Ordicab-Electron",
  "scripts": {
    "format": "prettier --write .",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && npm run package:mac:artifacts && npm run package:win:artifacts",
    "package:mac": "npm run build && npm run package:mac:artifacts",
    "package:win": "npm run build && npm run package:win:artifacts",
    "package:mac:artifacts": "electron-builder --config electron-builder.config.ts --mac dmg zip --arm64 --publish never",
    "package:win:artifacts": "electron-builder --config electron-builder.config.ts --win nsis --x64 --publish never",
    "publish:mac": "bash scripts/publish-mac.sh",
    "publish:win": "bash scripts/publish-win.sh",
    "publish": "bash scripts/publish.sh",
    "package:dir": "npm run build && electron-builder --config electron-builder.config.ts --dir --publish never",
    "postinstall": "electron-builder install-app-deps && node scripts/rename-electron-dev.js",
    "build:unpack": "npm run package:dir",
    "build:win": "npm run package:win",
    "build:mac": "npm run package:mac",
    "build:linux": "npm run build && electron-builder --config electron-builder.config.ts --linux AppImage --x64 --publish never"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@floating-ui/dom": "^1.7.6",
    "@kenjiuno/msgreader": "^1.28.0",
    "@mistralai/mistralai": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.22",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-font-family": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "ai": "^6.0.158",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "docxtemplater": "^3.68.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.2",
    "html-to-docx": "^1.8.0",
    "html-to-text": "^9.0.5",
    "i18next": "^25.8.18",
    "immer": "^11.1.4",
    "mailparser": "^3.9.4",
    "mammoth": "^1.12.0",
    "ollama": "^0.6.3",
    "pdfjs-dist": "^5.5.207",
    "pizzip": "^3.2.0",
    "react-i18next": "^16.5.8",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "utif": "^3.1.0",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.0.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
